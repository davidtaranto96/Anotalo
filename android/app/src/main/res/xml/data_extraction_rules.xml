<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) data extraction rules.
    Splits "cloud-backup" (Google Drive across reinstalls) from
    "device-transfer" (phone-to-phone migration).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="arquitectura_enfoque.db" />
        <include domain="file" path="arquitectura_enfoque.db-journal" />
        <include domain="file" path="arquitectura_enfoque.db-wal" />
        <include domain="file" path="arquitectura_enfoque.db-shm" />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="arquitectura_enfoque.db" />
        <include domain="file" path="arquitectura_enfoque.db-journal" />
        <include domain="file" path="arquitectura_enfoque.db-wal" />
        <include domain="file" path="arquitectura_enfoque.db-shm" />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
