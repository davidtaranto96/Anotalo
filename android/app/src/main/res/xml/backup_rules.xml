<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup rules — pre-Android 12 (API < 31).
    Backs up the Drift database + shared preferences to Google Drive so the
    user's data survives app reinstalls (up to 25MB free per user).
-->
<full-backup-content>
    <!-- Drift database (app documents dir) -->
    <include domain="file" path="arquitectura_enfoque.db" />
    <include domain="file" path="arquitectura_enfoque.db-journal" />
    <include domain="file" path="arquitectura_enfoque.db-wal" />
    <include domain="file" path="arquitectura_enfoque.db-shm" />
    <!-- SharedPreferences (theme, reminder time, etc.) -->
    <include domain="sharedpref" path="." />
</full-backup-content>
